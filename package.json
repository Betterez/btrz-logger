{
  "name": "btrz-logger",
  "version": "6.2.0",
  "description": "A multi-transport logger",
  "main": "index.js",
  "scripts": {
    "preversion": "npm test",
    "postversion": "git push origin master && git push --tags",
    "version": "git tag $1",
    "test": "node --test --test-force-exit test/*.js",
    "test-w": "node --test --test-force-exit --watch test/*.js",
    "prepare": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Betterez/btrz-logger.git"
  },
  "keywords": [
    "Logging",
    "logger",
    "log-entries",
    "console"
  ],
  "author": "Betterez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Betterez/btrz-logger/issues"
  },
  "homepage": "https://github.com/Betterez/btrz-logger#readme",
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "ansi-color": "0.2.2",
    "bson": "1.1.6",
    "lodash.memoize": "4.1.2",
    "r7insight_node": "3.3.1",
    "rotating-file-stream": "3.2.9"
  },
  "devDependencies": {
    "chance": "1.1.13"
  }
}
